{
    "name": "cowork-agent",
    "version": "1.0.0",
    "description": "Direct-connect WebSocket bridge that lets cowork-webapp talk to a local Claude or Gemini CLI",
    "license": "MIT",
    "type": "module",
    "engines": {
        "node": ">=20.0.0"
    },
    "main": "./dist/index.js",
    "bin": {
        "cowork-agent": "./bin/cowork-agent.mjs"
    },
    "files": [
        "bin",
        "dist"
    ],
    "scripts": {
        "dev": "tsx src/index.ts",
        "start": "tsx src/index.ts",
        "typecheck": "tsc --noEmit",
        "build": "tsc -p tsconfig.build.json",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "chalk": "^5.6.2",
        "qrcode-terminal": "^0.12.0",
        "tweetnacl": "^1.0.3",
        "ws": "^8.19.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": ">=20",
        "@types/qrcode-terminal": "^0.12.2",
        "@types/ws": "^8.18.1",
        "tsx": "^4.20.6",
        "typescript": "~5.9.3",
        "vitest": "^3.2.4"
    }
}
