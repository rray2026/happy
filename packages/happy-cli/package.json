{
  "name": "happy",
  "version": "1.1.6",
  "description": "Mobile and Web client for Claude Code and Codex",
  "author": "Kirill Dubovitskiy",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "homepage": "https://happy.engineering",
  "bugs": "https://github.com/slopus/happy/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/slopus/happy"
  },
  "bin": {
    "happy": "./bin/happy.mjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist",
    "bin",
    "package.json"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "shx rm -rf dist && tsc --noEmit && pkgroll",
    "test": "$npm_execpath run build && vitest run",
    "start": "$npm_execpath run build && node ./bin/happy.mjs",
    "cli": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "$npm_execpath run build && $npm_execpath test",
    "release": "npx --no-install release-it"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "qrcode-terminal": "^0.12.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": ">=20",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.18.1",
    "pkgroll": "^2.14.2",
    "shx": "^0.3.3",
    "tsx": "^4.20.6",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "packageManager": "pnpm@10.11.0"
}
